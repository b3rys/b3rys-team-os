# --- Required ---
# 경로는 repo 기준 상대경로(어느 머신서나 동작). 다른 위치면 절대경로로.
TEAM_DB_PATH=./team.db
TEAM_HTTP_PORT=7878
TEAM_BIND=127.0.0.1
TEAM_AGENT_REGISTRY=./agents.json
BASE_PATH=/team

# 내장 예약 실행기: 기본 ON, 실제 실행. 점검만 하려면 DRY_RUN=1.
B3OS_SCHEDULER_ENABLED=true
B3OS_SCHEDULER_DRY_RUN=0

# 실행 모드: 미설정=공개(public, 기본·fail-safe) / =1 이면 라이브(live, 풀 기능).
#   라이브 전용 기능(codex·b3os_native 런타임, 전체 핵심룰 재적용/롤백, 런타임 swap UI, 배포 메뉴)은
#   B3OS_LIVE=1 에서만 켜진다. 팀을 실제 운영하는 정본 인스턴스에서만 1로 두세요. (상세: docs/BUILD_MODES.md)
# B3OS_LIVE=1

# --- Optional (Phase 2+) ---
TEAM_MAX_HOPS=5
TEAM_MODERATOR_TIMEOUT_SEC=60
TEAM_CF_ACCESS_REQUIRED=false

# --- OpenClaw gateway probe ---
OPENCLAW_GATEWAY_URL=http://127.0.0.1:18789

# ─── 텔레그램 그룹/유저 (다운로드 후 본인 값으로) ───────────────
# 팀 그룹 chat_id (capture·router·digest 가 이 그룹만 처리). 예: -1001234567890
CAPTURE_GROUP_ID=
TEAM_GROUP_ID=
# 운영자(GD) 1:1 DM chat_id (시스템 알림 수신)
GD_CHAT_ID=

# ─── 기본 협업 floor (★agent 가 그룹 메시지 받고 응답하려면 필수) ───────────────
# 권장: 이 값들은 .env 대신 대시보드 Settings ▸ 시스템 OP 에서 설정(토큰은 0600 secrets 파일로 저장·UI엔 노출 안 됨).
# .env 는 bootstrap/fallback 용. (P0 — 미설정 시 대시보드·칸반·BWF·proposal 은 되나 agent 가 그룹 대화에 응답 안 함.)
# team-op(capture) 봇 토큰 — 그룹 메시지를 읽어 bus 에 넣는 운영 봇. BotFather 에서 발급.
CAPTURE_BOT_TOKEN=
# 라우터 ON 이어야 agent 를 실제로 깨워 응답시킴(OFF=shadow: 결정만 로그·응답 안 함). 기본 false.
ROUTER_ENABLED=false
# ─── 스케줄러 (칸반 과제리뷰·주간 잡 자동 실행) ───────────────
# 서버 내장 스케줄러 — 켜면 매일 과제리뷰(06:00 팀원 핑 / 06:20 팀장 요약 DM)와 주간 잡을 자동 발화한다.
#   ★공개(개인 장비)는 기본 ON★: 라이브는 이 잡들을 launchd(macOS)로 돌리는데 공개 빌드엔 launchd 가 없어,
#   이 내장 스케줄러가 그 역할을 한다(포터블). ENABLED=true 이고 DRY_RUN=0 이어야 실제 발화(둘 중 하나만이면 dry/off).
#   요약 DM 은 팀장 chat_id(대시보드 Settings 에서 페어링) 설정 시 전송, 미설정이면 조용히 보류(무해).
B3OS_SCHEDULER_ENABLED=true
B3OS_SCHEDULER_DRY_RUN=0
# 런타임 활성화(영입 시 실제 봇 기동) 권한 스위치. 기본 미설정=OFF → 대시보드 영입이 "권한 OFF"로 막힘.
#   ★본인 전용 장비(personal machine)에서 b3os를 쓰는 경우, 대시보드 접근=본인 인가로 보고 1로 설정하세요.★
#   공용/노출 서버라면 절대 1로 두지 마세요(엣지 인증 앞단 필수). = b3os는 개인 장비 전제.
APPROVAL_EXECUTION_ENABLED=

# ─── Slack 연동 (선택) ───────────────
# 공개 base URL — Slack 재설치 마법사가 Event Subscriptions URL·재설치 링크를 이 도메인으로 만든다.
#   ★미설정 시 빈 값이며 링크는 상대경로로 폴백합니다. 슬랙/외부 연동을 쓰면 본인 도메인·터널 주소로 설정하세요.★
#   (Slack 을 안 쓰면 무시해도 됨.)
TEAM_PUBLIC_BASE_URL=

# 텔레그램 이미지/미디어 저장 위치. 미설정 시 <설치폴더>/../team-media (첫 이미지 수신 시 자동생성, 0700). GD 2026-07-02
# TEAM_MEDIA_DIR=/absolute/path/to/team-media
